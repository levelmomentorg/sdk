// LevelMoment — read student token from launch URL or deep link.

private string GetTokenFromUrl()
{
#if UNITY_WEBGL && !UNITY_EDITOR
    var uri = new System.Uri(Application.absoluteURL);
    var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
    return query["token"] ?? string.Empty;
#elif UNITY_ANDROID && !UNITY_EDITOR
    using var activity = new AndroidJavaClass("com.unity3d.player.UnityPlayer")
        .GetStatic<AndroidJavaObject>("currentActivity");
    var intent = activity.Call<AndroidJavaObject>("getIntent");
    var data = intent.Call<AndroidJavaObject>("getData");
    if (data == null) return string.Empty;
    var url = data.Call<string>("toString");
    var uri = new System.Uri(url);
    var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
    return query["token"] ?? string.Empty;
#else
    // LEVELMOMENT_TODO: implement for iOS deep link (Universal Links / NSUserActivity)
    return string.Empty;
#endif
}

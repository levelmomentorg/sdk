// === LevelMoment integration ===
// Generated by /levelmoment. See https://app.levelmoment.com/docs/getting-started

import { LevelMomentWebClient, type LevelMomentWebAd } from "@levelmoment/sdk-web";

const client = LevelMomentWebClient.initialize({
  apiUrl: "{{API_URL}}",
  placementId: "{{PLACEMENT_ID}}",
  studentToken: new URLSearchParams(location.search).get("token") ?? "",
});

client.start();

let pendingAd: LevelMomentWebAd | null = null;

function preloadNextAd() {
  client.loadAd({
    onAdLoaded: (ad) => {
      pendingAd = ad;
    },
    onAdFailedToLoad: (err) => {
      console.warn("[LevelMoment] load failed", err);
    },
  });
}

preloadNextAd();

// Call this at natural pause points (level complete, lives lost, etc.).
// `onReward` is called on a correct answer; `onResume` always fires.
export function showAdBreak(opts?: {
  onReward?: () => void;
  onResume?: () => void;
}) {
  if (!pendingAd || !pendingAd.isLoaded()) return false;
  pendingAd.show({
    onUserEarnedReward: (reward) => {
      if (reward.amount === 1) opts?.onReward?.();
    },
    onAdDismissed: () => {
      pendingAd = null;
      opts?.onResume?.();
      preloadNextAd();
    },
  });
  return true;
}
// === end LevelMoment integration ===

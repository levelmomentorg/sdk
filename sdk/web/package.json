{
  "name": "@levelmoment/sdk-web",
  "version": "0.1.2",
  "description": "LevelMoment SDK for web and HTML5 games — educational question breaks that replace rewarded ads",
  "keywords": [
    "levelmoment",
    "education",
    "ads",
    "rewarded-ads",
    "games",
    "html5",
    "phaser"
  ],
  "homepage": "https://github.com/levelmomentorg/sdk/tree/main/sdk/web#readme",
  "bugs": {
    "url": "https://github.com/levelmomentorg/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/levelmomentorg/sdk.git",
    "directory": "sdk/web"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "claude"
  ],
  "bin": {
    "install-skill": "./bin/install-skill.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "prepack": "node ../../tools/claude-skill-levelmoment/scripts/bundle-into.mjs .",
    "postpack": "rm -rf claude"
  },
  "dependencies": {
    "@levelmoment/sdk-core": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "5.4.5"
  }
}
